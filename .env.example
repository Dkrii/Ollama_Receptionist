APP_ENV=development
APP_URL=http://localhost:8000
CONTACT_MESSAGING_PROVIDER=wablas

AI_PROVIDER=openrouter

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small
OPENROUTER_SITE_NAME=Virtual Receptionist Kiosk

# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_CHAT_MODEL=qwen2.5:3b
# OLLAMA_EMBED_MODEL=nomic-embed-text

CHROMA_HOST=chroma
CHROMA_PORT=8000

RAG_TOP_K=2
RAG_SCORE_THRESHOLD=0.72

DB_POSTGRES_DRIVER=postgres
DB_POSTGRES_HOST=localhost
DB_POSTGRES_PORT=5432
DB_POSTGRES_NAME=receptionist
DB_POSTGRES_USER=
DB_POSTGRES_PASSWORD=
DB_POSTGRES_TIMEOUT_SECONDS=10

DB_MSSQL_DRIVER=mssql
DB_MSSQL_HOST=
DB_MSSQL_PORT=1433
DB_MSSQL_NAME=
DB_MSSQL_USER=
DB_MSSQL_PASSWORD=
DB_MSSQL_TIMEOUT_SECONDS=10

CHAT_DB_PATH=/workspace/runtime/chat.sqlite3
CHAT_SESSION_IDLE_MINUTES=5
CHAT_RECENT_TURNS=4
CHAT_HISTORY_MAX_CHARS=600
CHAT_TRANSCRIPT_RETENTION_DAYS=7
CHAT_INTENT_TIMEOUT_SECONDS=20

WABLAS_BASE_URL=https://wablas.com
WABLAS_TOKEN=
WABLAS_SECRET_KEY=
WABLAS_TIMEOUT_SECONDS=15
WABLAS_RETRY_ATTEMPTS=3
WABLAS_RETRY_BACKOFF_SECONDS=0.4
# WABLAS_TEST_GROUP_ID=1203630xxxxxxxx@g.us

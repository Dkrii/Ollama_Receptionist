APP_PORT=8000
APP_HOST=0.0.0.0

AI_PROVIDER=openrouter

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_SITE_NAME=Virtual Receptionist Kiosk

# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_CHAT_MODEL=qwen2.5:3b
# OLLAMA_EMBED_MODEL=nomic-embed-text
# Kurangi panjang jawaban default agar decode token lebih cepat
OLLAMA_NUM_PREDICT=96
# Respons ringkas untuk pertanyaan sederhana
OLLAMA_NUM_PREDICT_SHORT=64
# Batas jawaban detail tetap ada, tapi lebih terkendali
OLLAMA_NUM_PREDICT_LONG=192
OLLAMA_NUM_CTX=2048
# Optimasi untuk i7-9750H (12 logical threads): gunakan 8 worker thread
OLLAMA_NUM_THREAD=8
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION=receptionist_kb
RAG_TOP_K=2
RAG_SCORE_THRESHOLD=0.72
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150
# Potong konteks retrieval untuk menurunkan beban prefill LLM
RAG_MAX_CONTEXT_CHARS=1000
CHAT_DB_PATH=/workspace/runtime/chat.sqlite3
CHAT_SESSION_IDLE_MINUTES=5
# Batasi turn history agar prompt lebih ringan
CHAT_RECENT_TURNS=4
# Pangkas karakter history agar first-token lebih cepat
CHAT_HISTORY_MAX_CHARS=600
CHAT_TRANSCRIPT_RETENTION_DAYS=7
CHAT_INTENT_TIMEOUT_SECONDS=20
CONTACT_DEFAULT_MODE=notify
CONTACT_CALL_MODE=dummy
CONTACT_MESSAGE_DELIVERY_MODE=dummy
WHATSAPP_API_BASE_URL=
WHATSAPP_API_KEY=
WHATSAPP_SENDER_ID=
WHATSAPP_TIMEOUT_SECONDS=15

# HNSW tuning untuk stabilitas collection Chroma (hindari ef/M terlalu kecil)
CHROMA_HNSW_M=32
CHROMA_HNSW_CONSTRUCTION_EF=200
CHROMA_HNSW_SEARCH_EF=80
CHROMA_HNSW_SPACE=cosine

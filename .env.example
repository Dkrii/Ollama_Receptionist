APP_ENV=development
APP_URL=http://localhost:8000
CONTACT_CALL_PROVIDER=twilio
CONTACT_MESSAGING_PROVIDER=wablas

AI_PROVIDER=openrouter

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small
OPENROUTER_SITE_NAME=Virtual Receptionist Kiosk

# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_CHAT_MODEL=qwen2.5:3b
# OLLAMA_EMBED_MODEL=nomic-embed-text

OLLAMA_NUM_PREDICT=96
OLLAMA_NUM_PREDICT_SHORT=64
OLLAMA_NUM_PREDICT_LONG=192
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_THREAD=8

CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION=receptionist_kb
CHROMA_HNSW_M=32
CHROMA_HNSW_CONSTRUCTION_EF=200
CHROMA_HNSW_SEARCH_EF=80
CHROMA_HNSW_SPACE=cosine

RAG_TOP_K=2
RAG_SCORE_THRESHOLD=0.72
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150
RAG_MAX_CONTEXT_CHARS=1000

CHAT_DB_PATH=/workspace/runtime/chat.sqlite3
CHAT_SESSION_IDLE_MINUTES=5
CHAT_RECENT_TURNS=4
CHAT_HISTORY_MAX_CHARS=600
CHAT_TRANSCRIPT_RETENTION_DAYS=7
CHAT_INTENT_TIMEOUT_SECONDS=20

TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_TWIML_APP_SID=
CONTACT_CALL_FROM_NUMBER=

WABLAS_BASE_URL=https://wablas.com
WABLAS_TOKEN=
WABLAS_SECRET_KEY=
WABLAS_TIMEOUT_SECONDS=15
# Temporary testing only: uncomment to force all outbound Wablas messages into a WhatsApp group.
# WABLAS_TEST_GROUP_ID=1203630xxxxxxxx@g.us
